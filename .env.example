# Local/free embeddings for both ingestion and retrieval.
# Uses Chroma's ONNX MiniLM backend, avoiding scipy/torch/sentence-transformers.
# Delete and rebuild vectorstore/ after changing embedding backend.
EMBEDDING_MODEL=chroma-default-onnx-minilm-l6-v2

# Choose chat provider: openrouter or openai.
LLM_PROVIDER=openrouter

# OpenRouter chat settings.
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Uses OpenRouter's free-model router. To pin a specific free model,
# choose a current model ID from https://openrouter.ai/models?max_price=0.
OPENROUTER_MODEL=openrouter/free

# OpenAI chat settings.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
